{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Read",
			"Grep",
			"Glob",
			"Bash(Rscript *)",
			"Bash(git status*)",
			"Bash(git diff*)",
			"Bash(git log*)",
			"Bash(git show*)",
			"Bash(git blame*)",
			"Bash(gh api *)",
			"Bash(gh pr view*)",
			"Bash(gh issue view*)",
			"Bash(air format *)",
			"Bash(air check *)"
		],
		"deny": [
			"Bash(git push*)",
			"Bash(git reset --hard*)",
			"Bash(git clean*)",
			"Bash(git branch -D*)",
			"Bash(rm *)",
			"Bash(rm -rf *)"
		]
	}
}
